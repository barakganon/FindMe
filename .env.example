 # ============================================================
# BuyMe Smart Search — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/buyme_search
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/buyme_search  # for Alembic CLI

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Google Gemini API ---
GEMINI_API_KEY=

# --- Geolocation ---
# Used for resolving store addresses to lat/lng coordinates
GEOCODING_API_KEY=        # Google Maps Geocoding API or OpenCage
GEOCODING_PROVIDER=google# google | opencage

# --- Application ---
APP_ENV=development        # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- CORS (comma-separated allowed origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Raw data storage ---
# Local path or S3 URI (s3://bucket/prefix)
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# --- S3 (optional — leave blank to use local filesystem) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# --- Scrape schedule (cron expressions) ---
SCRAPE_POPULAR_STORES_CRON=0 3 * * *   # daily at 3am
SCRAPE_ALL_STORES_CRON=0 4 * * 0       # weekly on Sunday at 4am

# --- Cache TTLs (seconds) ---
SEARCH_CACHE_TTL=300
INTENT_CACHE_TTL=120

# --- Scraper limits ---
EMBED_BATCH_SIZE=100
SHOPIFY_SCRAPE_CONCURRENCY=5

# --- Google APIs (geocoding + OAuth) ---
GOOGLE_MAPS_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth ---
JWT_SECRET=your-secret-key-change-in-production
