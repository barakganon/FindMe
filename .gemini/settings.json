{
  "model": {
    "id": "gemini-3.1-flash-lite-preview"
  },
  "general": {
    "autoApprovalMode": "auto_edit",
    "checkpointing": {
      "enabled": true
    }
  },
  "context": {
    "fileName": ["GEMINI.md", "CLAUDE.md", "STATUS.md"],
    "fileFiltering": {
      "respectGitIgnore": true
    }
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PAT"
      }
    }
  }
}